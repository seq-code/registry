<h2>Actions</h2>
<ul class="nav flex-column">
  <li class="nav-item">
    <%= link_to(notifications_path, class: 'nav-link') do %>
      <%= fa_icon('bell') %>
      See all user notifications
    <% end %>
  </li>

  <li class="nav-item">
    <%= link_to(edit_user_registration_path, class: 'nav-link') do %>
      <%= fa_icon('user-cog') %>
      Edit profile information and settings
    <% end %>
  </li>

  <% unless current_contributor? %>
    <li class="nav-item">
      <%= link_to(contributor_request_path, class: 'nav-link') do %>
        <%= fa_icon('user-plus') %>
        Request contributor status
      <% end %>
    </li>
  <% end %>

  <% unless current_curator? %>
    <li class="nav-item">
      <%= link_to(curator_request_path, class: 'nav-link') do %>
        <%= fa_icon('user-check') %> Request curator status
      <% end %>
    </li>
  <% end %>

  <% unless current_community_member? %>
    <li class="nav-item">
      <%= link_to(
            'https://forms.gle/FWMb3JnUpVDt7TXXA',
            class: 'nav-link', target: '_blank'
          ) do %>
        <%= fa_icon('users') %> Become a SeqCode Community member
      <% end %>
    </li>
  <% end %>

  <li class="nav-item">
    <% if current_user.wikispecies_credential %>
      <%= link_to(
            wikispecies_oauth_disconnect_path, method: :delete,
            data: { confirm: 'Disconnect your Wikimedia account?' },
            class: 'nav-link'
          ) do %>
        <%= fa_icon('wikipedia-w', type: 'fab') %>
        Disconnect Wikimedia:
        <b><%= current_user.wikispecies_credential.wiki_username %></b>
      <% end %>
    <% else %>
      <%= link_to(wikispecies_oauth_authorize_path, class: 'nav-link') do %>
        <%= fa_icon('wikipedia-w', type: 'fab') %>
        Connect your Wikimedia account
      <% end %>
    <% end %>
  </li>

  <% if false # Do not include this option for now %>
    <li class='nav-item'>
      <%= link_to(
            user_registration_path,
            data: { confirm: 'Are you sure?' },
            method: :delete, class: 'nav-link '
          ) do %>
        <%= fa_icon('user-minus') %> Remove my account
      <% end %>
    </li>
  <% end %>
</ul>
