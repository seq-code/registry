<% if current_editor? && @register.validated? %>
  <dl class="main-section name-details actions-section">
    <h2>Editor Actions</h2>
    <dd>
      <% if @register.published? %>
        <%= link_to(
              editorial_checks_register_url(@register),
              class: 'btn btn-primary btn-sm'
            ) do %>
          <%= fa_icon('cubes') %> Revise editorial checks
        <% end %>
        &raquo; Evaluate editorial checks post-publication
      <% else %>
        <%= link_to(
              publish_register_url(@register),
              class: 'btn btn-primary btn-sm'
            ) do %>
          <%= fa_icon('satellite-dish') %> Publish list
        <% end %>
        &raquo; Register and transfer documents as displayed above
      <% end %>
      <% if @register.validated? %>
        <hr/>
        <%= link_to(
              post_validation_note_register_url(@register),
              class: 'btn btn-primary btn-sm'
            ) do %>
          <%= fa_icon('glasses') %> Post-validation note
        <% end %>
        &raquo; Add public notes after validation
      <% end %>
    </dd>
  </dl>
<% end %>

